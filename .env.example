# ========================================
# CONFIGURAÇÃO SUPABASE - EXEMPLO
# ========================================
# NUNCA COMMITAR ESTE ARQUIVO COM VALORES REAIS!22
# Use .env.local para desenvolvimento local
# Use GitHub Secrets para produção

# ========================================
# Supabase API (obtém em: https://supabase.com/dashboard/project/xxxxx/settings/api)
# ========================================

# URL do project Supabase (pode ser exposto - é pública)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anon/pública (pode ser exposta - é usada no frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# Supabase Admin (para servidor/CLI apenas)
# ⚠️ NUNCA expor isso publicamente! ⚠️
# ========================================

# Chave de serviço (secreto - apenas backend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database password (secreto - apenas local/admin)
SUPABASE_DB_PASSWORD=sua-senha-super-segura-aqui

# ========================================
# Supabase CLI (para desenvolvimento local)
# ========================================

# Access token para CLI (obtém em: https://supabase.com/dashboard/account/tokens)
# Salve em local seguro! NÃO commitar!
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Project ID (pode ser exposto - é do domínio público)
SUPABASE_PROJECT_ID=sua-projeto-id

# ========================================
# Desenvolvimento Local
# ========================================

# URLs quando rodando com 'npm run db:start'
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# GitHub Actions Secrets
# ========================================
# ADICIONE NO GITHUB REPOSITORY SETTINGS:
# Settings → Secrets and variables → Actions → New repository secret
# 
# SECRETS NECESSÁRIOS:
# - SUPABASE_ACCESS_TOKEN (seu token de acesso)
# - SUPABASE_DB_PASSWORD (senha do banco)
# - SUPABASE_PROJECT_ID (ID do projeto)
#
# Exemplo:
# Name: SUPABASE_ACCESS_TOKEN
# Value: sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
